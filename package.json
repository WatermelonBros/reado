{
  "name": "reado",
  "private": true,
  "version": "0.17.0",
  "type": "module",
  "description": "Reado — a calm, read-first code IDE where comments are durable, AI-resolvable artifacts.",
  "license": "MIT",
  "packageManager": "pnpm@10.26.2",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "tauri",
    "tauri:dev": "bash scripts/bundle-cli.sh && tauri dev",
    "tauri:build": "bash scripts/bundle-cli.sh && tauri build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "cli:install": "bash scripts/install-cli.sh",
    "release": "bash scripts/release.sh",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest run --project ui",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@ark-ui/react": "^5.37.2",
    "@codemirror/commands": "^6.7.1",
    "@codemirror/language": "^6.10.8",
    "@codemirror/language-data": "^6.5.1",
    "@codemirror/lint": "^6.9.7",
    "@codemirror/lsp-client": "^6.2.5",
    "@codemirror/merge": "^6.12.2",
    "@codemirror/search": "^6.5.8",
    "@codemirror/state": "^6.5.0",
    "@codemirror/view": "^6.36.1",
    "@lezer/highlight": "^1.2.1",
    "@replit/codemirror-indentation-markers": "^6.5.3",
    "@replit/codemirror-lang-solidity": "^6.0.2",
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-clipboard-manager": "^2.3.2",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/addon-search": "^0.16.0",
    "@xterm/addon-web-links": "^0.12.0",
    "@xterm/xterm": "^6.0.0",
    "fuzzysort": "^3.1.0",
    "i18next": "^26.3.1",
    "qrcode": "^1.5.4",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "react-i18next": "^17.0.8",
    "react-markdown": "^9.0.3",
    "rehype-raw": "^7.0.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.3.1",
    "@tauri-apps/cli": "^2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "@vitest/coverage-v8": "^4.1.9",
    "happy-dom": "^20.10.6",
    "tailwindcss": "^4.3.1",
    "typescript": "~5.8.3",
    "vite": "^7.0.4",
    "vitest": "^4.1.9"
  }
}
