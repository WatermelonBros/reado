{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Reado",
  "version": "0.1.0",
  "identifier": "com.reado.app",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Reado",
        "width": 1280,
        "height": 832,
        "minWidth": 720,
        "minHeight": 480
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": ["binaries/reado-cli"],
    "createUpdaterArtifacts": true,
    "category": "DeveloperTool",
    "shortDescription": "A calm, read-first code IDE.",
    "longDescription": "Reado inverts the IDE: the primary experience is reading code, and the primary action is leaving durable comments that an AI agent resolves.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/WatermelonBros/reado/releases/latest/download/latest.json"
      ],
      "pubkey": "ZFc1MGNuVnpkR1ZrSUdOdmJXMWxiblE2SUcxcGJtbHphV2R1SUhCMVlteHBZeUJyWlhrNklEVXdRams0TmpJM1JUQkVRamREUWtVS1VsZFRLMlpPZG1kS05HRTFWVWRsT1VSNE9XVTNOR2N2YWpkT1RreHFSa3BZUlZCdGJIZHpPRk5aUmpKS1IxcFFMM1JaT0RNNVJIY0s="
    }
  }
}
