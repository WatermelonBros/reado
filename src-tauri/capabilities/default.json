{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the launcher and project windows",
  "windows": ["main", "project_*"],
  "permissions": [
    "core:default",
    "core:event:default",
    "core:webview:allow-create-webview-window",
    "core:webview:allow-set-webview-zoom",
    "core:window:allow-set-focus",
    "core:window:allow-set-title",
    "core:window:allow-set-theme",
    "opener:default",
    "dialog:default",
    "store:default",
    "updater:default",
    "process:default"
  ]
}
